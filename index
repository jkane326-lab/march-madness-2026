<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Q1 TPS Report: Strategic Hoops Alignment</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <link rel="stylesheet" href="styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

<header>
    <h1>Q1 TPS Report: Candidate Selection</h1>
    <p>Select your candidates. Generate your PDF receipt. Pay the processing fee.</p>
    
    <div class="toggle-container">
        <button id="btn-mens" class="toggle-btn active" onclick="switchBracket('mens')">Men's Division</button>
        <button id="btn-womens" class="toggle-btn" onclick="switchBracket('womens')">Women's Division</button>
    </div>
</header>

<main class="container">
    <div id="pdf-content">
        <h2 id="current-division-title">Men's Division Candidates</h2>
        <div id="bracket-container"></div>
    </div>

    <form id="tps-form" class="user-info">
        <h3>Finalize Report</h3>
        <label for="username">Stakeholder Name:</label>
        <input type="text" id="username" name="username" required placeholder="Lumbergh, Bill">
        
        <label for="email">Email Address:</label>
        <input type="email" id="email" name="email" required placeholder="bill@initech.com">

        <div class="action-buttons">
            <button type="button" class="pdf-btn" onclick="downloadPDF()">1. Download PDF Receipt</button>
            <button type="submit" class="submit-btn" id="submit-btn">2. Submit to Management</button>
        </div>
    </form>

    <div id="success-message">
        <h2>Report Filed Successfully!</h2>
        <p>Your candidate selections have been logged. To ensure eligibility for the final review incentive program, please submit your $5 processing fee.</p>
        <a href="https://paypal.me/TheJasonKane" target="_blank" class="pay-link">Submit $5 Processing Fee via PayPal</a>
        <br><br>
        <p>Or Venmo: @Jeanette-Kane</p>
    </div>
</main>

<script src="app.js"></script>
</body>
</html>